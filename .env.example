# ===========================================
# RG Propiedades - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Required in production ---

# Secret key for signing JWT tokens (use a strong random string, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-here

# Admin credentials for initial database seed
ADMIN_EMAIL=admin@rgpropiedades.com
ADMIN_PASSWORD=your-strong-admin-password

# Allowed CORS origin (your domain)
CORS_ORIGIN=https://rossiguarino.com

# --- Optional ---

# Server port (default: 3001)
PORT=3001

# Node environment (development | production)
NODE_ENV=production

# Force re-seed database (default: false in production)
SEED_DB=false
